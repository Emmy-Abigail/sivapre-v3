# ─── Entorno ──────────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=sivapre
POSTGRES_PASSWORD=CAMBIAR_password_fuerte_aqui
POSTGRES_DB=sivapre_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sivapre:CAMBIAR_password_fuerte_aqui@db:5432/sivapre_db

# ─── Redis ────────────────────────────────────────────────────────────────────
# Apunta al servicio "redis" del docker-compose. No cambiar salvo que uses Redis externo.
REDIS_URL=redis://redis:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET_KEY=CAMBIAR_clave_secreta_minimo_32_caracteres
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Storage de fotos ─────────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=/app/uploads

# URL pública del backend — se guarda en la BD como prefijo de cada foto.
# Debe ser accesible desde el celular Y desde el dashboard.
# Ejemplo con IP:     http://203.0.113.10:8000
# Ejemplo con dominio: https://api.sivapre.gob.pe
MEDIA_BASE_URL=http://IP_DEL_VPS:8000

# ─── Seguridad ────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
ADMIN_SECRET_KEY=CAMBIAR_clave_admin_secreta

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origen del dashboard web (el navegador envía este header).
# La app móvil NO usa CORS — solo el navegador del dashboard lo necesita.
# Si el dashboard está en el mismo VPS en puerto 3000:
ALLOWED_ORIGINS=["http://IP_DEL_VPS:3000"]

# ─── pgAdmin (opcional — puedes deshabilitar en producción) ───────────────────
PGADMIN_EMAIL=admin@sivapre.com
PGADMIN_PASSWORD=CAMBIAR_password_pgadmin

# ─── Entorno ───────────────────────────────────────────────
APP_ENV=development        # development | production
DEBUG=True                 # True | False

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=db           # nombre del servicio en docker-compose
POSTGRES_PORT=5432         # puerto interno Docker; desde el host usar 5433

# ─── SQLAlchemy async (asyncpg) ──────────────────────────────
# Generar con los valores anteriores:
# postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=

# ─── JWT ────────────────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Cloudinary ─────────────────────────────────────────────
# Obtener en: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── pgAdmin (solo desarrollo) ───────────────────────────────
PGADMIN_EMAIL=
PGADMIN_PASSWORD=
